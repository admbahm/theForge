# Directory containing Markdown job postings produced by OpenHunt.
OPENHUNT_OUTPUT_DIR="/absolute/path/to/your/Obsidian/vault/Market-Insights"

# Ollama remains the default and requires no paid API key.
LLM_PROVIDER="ollama"
# LLM_MODEL overrides the selected provider's model when set.
# LLM_MODEL="gemma4:e4b"
OLLAMA_API_URL="http://localhost:11434"
OLLAMA_MODEL="gemma4:e4b"

# BYOK provider settings. Store keys in your environment, never in this file.
# LLM_PROVIDER="openai"
# OPENAI_API_KEY_ENV="OPENAI_API_KEY"
# OPENAI_MODEL="gpt-4.1-mini"
# LLM_PROVIDER="gemini"
# GEMINI_API_KEY_ENV="GEMINI_API_KEY"
# GEMINI_MODEL="gemini-2.5-flash"
